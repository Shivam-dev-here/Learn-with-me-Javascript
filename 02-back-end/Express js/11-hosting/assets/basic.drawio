        </mxCell>
        <mxCell id="ntDWItxwqqcZmIw39lHz-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;" value="&lt;div style=&quot;&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;94&quot; data-start=&quot;72&quot;&gt;Parallax Scrolling&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;123&quot; data-start=&quot;99&quot;&gt;Scrollspy Navigation&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;148&quot; data-start=&quot;128&quot;&gt;Smooth Scrolling&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;178&quot; data-start=&quot;153&quot;&gt;Sticky Navigation Bar&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;222&quot; data-start=&quot;183&quot;&gt;Reveal on Scroll (Scroll Animation)&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;252&quot; data-start=&quot;227&quot;&gt;Tilt / 3D Card Effect&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;274&quot; data-start=&quot;257&quot;&gt;Hover Effects&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;296&quot; data-start=&quot;279&quot;&gt;Glassmorphism&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;316&quot; data-start=&quot;301&quot;&gt;Neumorphism&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;342&quot; data-start=&quot;321&quot;&gt;Typewriter Effect&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;369&quot; data-start=&quot;347&quot;&gt;Fade In / Fade Out&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;396&quot; data-start=&quot;374&quot;&gt;Zoom In / Zoom Out&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;419&quot; data-start=&quot;401&quot;&gt;Flip Animation&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;448&quot; data-start=&quot;424&quot;&gt;Particle Backgrounds&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;485&quot; data-start=&quot;453&quot;&gt;Cursor Trail / Custom Cursor&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;512&quot; data-start=&quot;490&quot;&gt;Infinite Scrolling&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;538&quot; data-start=&quot;517&quot;&gt;Lottie Animations&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;565&quot; data-start=&quot;543&quot;&gt;Confetti Animation&lt;/strong&gt;&lt;br&gt;&lt;strong style=&quot;background